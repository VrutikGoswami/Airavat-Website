# --- Map tiles -------------------------------------------------------------
# Style URL for MapLibre GL. Leave empty in development: the app falls back to
# the free MapLibre demo style (https://demotiles.maplibre.org/style.json).
# For production, point this at a styled tile service (MapTiler, Stadia,
# Protomaps, self-hosted) that matches the brand palette.
NEXT_PUBLIC_MAP_STYLE_URL=

# Optional provider API key, appended as ?key= to the style URL if your
# provider requires it. Never commit a real key.
NEXT_PUBLIC_MAP_PROVIDER_KEY=

# --- Site ------------------------------------------------------------------
# Canonical origin used for metadata, sitemap and robots. No trailing slash.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Future integrations (placeholders, unused in this release) -------------
# AMADEUS_CLIENT_ID=
# AMADEUS_CLIENT_SECRET=
# WHATSAPP_BUSINESS_TOKEN=
# CRM_WEBHOOK_URL=
# EMAIL_API_KEY=
